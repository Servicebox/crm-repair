# ===========================
# ServiceBox CRM — .env.example
# Скопируйте в .env и заполните своими значениями
# НИКОГДА не коммитьте .env с реальными данными!
# ===========================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/servicebox

# NextAuth
NEXTAUTH_URL=https://koznova.site
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_HERE

# JWT (используется для верификации email и сброса пароля)
JWT_SECRET=YOUR_JWT_SECRET_HERE

# Ключ шифрования для Server Actions
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# API-ключ для внешних интеграций (/api/v1/*)
ADMIN_API_KEY=YOUR_ADMIN_API_KEY_HERE

# SMTP (для отправки email)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=your-email@yandex.ru
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE
SMTP_FROM=noreply@your-domain.ru

# Telegram-боты (опционально)
SUPPORT_BOT_TOKEN=YOUR_SUPPORT_BOT_TOKEN_HERE
SUPPORT_CHAT_ID=YOUR_SUPPORT_CHAT_ID_HERE
NOTIFY_BOT_TOKEN=YOUR_NOTIFY_BOT_TOKEN_HERE
NOTIFY_CHAT_ID=YOUR_NOTIFY_CHAT_ID_HERE

# Устаревшие (оставлены для совместимости с Express/SQLite сервером)
PORT=3001
DATABASE_PATH=./data/crm.db
